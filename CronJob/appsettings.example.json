{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost,1433;Database=WhatsAppNotificationDb;User Id=sa;Password=YOUR_DB_PASSWORD;TrustServerCertificate=True;"
  },
  "Twilio": {
    "AccountSid": "YOUR_TWILIO_ACCOUNT_SID",
    "AuthToken": "YOUR_TWILIO_AUTH_TOKEN",
    "WhatsAppFrom": "whatsapp:+YOUR_TWILIO_SANDBOX_NUMBER"
  },
  "Quartz": {
    "CronSchedule": "0/30 * * * * ?"
  }
}