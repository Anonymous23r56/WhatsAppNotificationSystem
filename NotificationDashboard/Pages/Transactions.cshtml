@page
@model TransactionsModel
@{
    ViewData["Title"] = "Transactions";
}
@if (Model.SuccessMessage != null)
{
    <div id="successPopup" style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;z-index:999;">
        <div style="background:#fff;border-radius:12px;padding:2rem;max-width:400px;width:90%;text-align:center;">
            <div style="font-size:48px;margin-bottom:1rem;">✅</div>
            <div style="font-size:16px;font-weight:500;color:#1a1a1a;margin-bottom:0.5rem;">Transaction Successful!</div>
            <div style="font-size:14px;color:#888;margin-bottom:1.5rem;">@Model.SuccessMessage</div>
            <div style="font-size:13px;color:#1D9E75;margin-bottom:1.5rem;">WhatsApp notification has been sent 📱</div>
            <button onclick="closePopup()" style="background:#1D9E75;color:white;border:none;padding:10px 24px;border-radius:8px;font-size:14px;cursor:pointer;width:100%;">
                Make another transaction
            </button>
        </div>
    </div>
}

@if (Model.ErrorMessage != null)
{
    <div id="errorPopup" style="position:fixed;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,0.4);display:flex;align-items:center;justify-content:center;z-index:999;">
        <div style="background:#fff;border-radius:12px;padding:2rem;max-width:400px;width:90%;text-align:center;">
            <div style="font-size:48px;margin-bottom:1rem;">❌</div>
            <div style="font-size:16px;font-weight:500;color:#1a1a1a;margin-bottom:0.5rem;">Transaction Failed!</div>
            <div style="font-size:14px;color:#D85A30;margin-bottom:1.5rem;">@Model.ErrorMessage</div>
            <button onclick="closeError()" style="background:#D85A30;color:white;border:none;padding:10px 24px;border-radius:8px;font-size:14px;cursor:pointer;width:100%;">
                Try again
            </button>
        </div>
    </div>
}
<div class="page-title">Transactions</div>

@if (Model.SuccessMessage != null)
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}
@if (Model.ErrorMessage != null)
{
    <div class="alert alert-error">@Model.ErrorMessage</div>
}

<div class="card">
    <div class="card-title">New transaction</div>
    <form method="post">
        <div class="form-row">
            <div class="form-group">
                <label>Account</label>
                <select asp-for="AccountId" required>
                    <option value="">Select account</option>
                    @foreach (var acc in Model.Accounts)
                    {
                        <option value="@acc.Id">@acc.FullName — @acc.AccountNumber (₦@acc.Balance.ToString("N2"))</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Transaction type</label>
                <select asp-for="Type" id="txType" onchange="toggleTarget()">
                    <option value="Deposit">Deposit</option>
                    <option value="Withdraw">Withdraw</option>
                    <option value="Transfer">Transfer</option>
                </select>
            </div>
        </div>
        <div class="form-row">
            <div class="form-group">
                <label>Amount (₦)</label>
                <input type="number" asp-for="Amount" placeholder="10000" min="1" required />
            </div>
            <div class="form-group" id="targetGroup" style="display:none;">
                <label>Transfer to account</label>
                <select asp-for="TargetAccountId">
                    <option value="">Select target account</option>
                    @foreach (var acc in Model.Accounts)
                    {
                        <option value="@acc.Id">@acc.FullName — @acc.AccountNumber</option>
                    }
                </select>
            </div>
        </div>
        <div class="form-group">
            <label>Description</label>
            <input type="text" asp-for="Description" placeholder="e.g. Salary Payment" required />
        </div>
        <button type="submit" class="btn btn-primary">Submit transaction</button>
    </form>
</div>

