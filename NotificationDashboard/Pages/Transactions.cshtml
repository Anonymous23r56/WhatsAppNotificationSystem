<div class="card">
    <div class="card-title">Recent transactions</div>
    @if (!Model.RecentTransactions.Any())
    {
        <p style="font-size:14px;color:#888;">No transactions yet.</p>
    }
    @foreach (var tx in Model.RecentTransactions)
    {
        var iconClass = tx.Type == "Credit" ? "credit" : tx.Type == "Debit" ? "debit" : "transfer";
        var amtClass = tx.Type == "Credit" ? "credit" : "debit";
        var sign = tx.Type == "Credit" ? "+" : "-";
        <div class="tx-item">
            <div class="tx-icon @iconClass">@tx.Type[0]</div>
            <div class="tx-info">
                <div class="tx-desc">
                    @tx.Description
                    <span class="account-pill">@tx.AccountNumber</span>
                </div>
                <div class="tx-date">
                    @tx.TransactionRef · @tx.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                </div>
            </div>
            <div style="text-align:right;">
                <div class="tx-amount @amtClass">@sign₦@tx.Amount.ToString("N2")</div>
                <div class="tx-date">Bal: ₦@tx.BalanceAfter.ToString("N2")</div>
            </div>
        </div>
    }
</div>

<script>
    function toggleTarget() {
        var type = document.getElementById('txType').value;
        document.getElementById('targetGroup').style.display =
            type === 'Transfer' ? 'block' : 'none';
    }
</script>
<script>
    function closePopup() {
        document.getElementById('successPopup').style.display = 'none';
    }

    function closeError() {
        document.getElementById('errorPopup').style.display = 'none';
    }

    function toggleTarget() {
        var type = document.getElementById('txType').value;
        document.getElementById('targetGroup').style.display =
            type === 'Transfer' ? 'block' : 'none';
    }
</script>